import { NavLink } from "react-router-dom";

const navItems = [
  { label: "Home", path: "/" },
  { label: "Typing Test", path: "/typing-test" },
  { label: "Attention Test", path: "/attention-test" },
  { label: "Reading Test", path: "/reading-test" },
  { label: "Final Result", path: "/final-result" },
  { label: "History", path: "/history" },
];

const Navbar = () => {
  return (
    <nav className="w-full border-b border-gray-300 bg-white shadow-sm">
      <div className="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
        <div className="text-2xl font-bold text-blue-700">NeuroBehavior AI</div>

        <div className="flex flex-wrap items-center gap-2">
          {navItems.map((item) => (
            <NavLink
              key={item.path}
              to={item.path}
              className={({ isActive }) =>
                `rounded-lg px-4 py-2 text-sm font-semibold transition ${
                  isActive
                    ? "bg-blue-500 text-white"
                    : "bg-gray-100 text-gray-700 hover:bg-gray-200"
                }`
              }
            >
              {item.label}
            </NavLink>
          ))}
        </div>
      </div>
    </nav>
  );
};

export default Navbar;
